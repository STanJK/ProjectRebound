import { VerticalBox } from "std-widgets.slint";

export component SideBar {
    in property <[string]> model: [];
    out property <int> current-item: 0;

    VerticalBox {
        padding: 10px;
        spacing: 4px;

        for item[index] in root.model : Rectangle {
            height: 30px;

            // 背景色状态切换（选中 / 悬停 / 默认）
            background: index == root.current-item ? #5e84bd :
                        touch.has-hover ? #485974 : transparent;
            border-radius: 4px;
            animate background { duration: 150ms; }

            Text {
                text: item;
                vertical-alignment: center;
                // 左边距通过 x 或 horizontal-alignment 实现，完全合法
                x: 10px;
                height: 100%;
            }

            touch := TouchArea {
                clicked => { root.current-item = index; }
            }
        }
    }
}